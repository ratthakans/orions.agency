# Supabase — stores contact-form submissions. Copy to `.env` and fill in.
# Values come from your Supabase project settings → API.
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# Web3Forms — emails the studio inbox on each contact-form submission.
# Sign up free at https://web3forms.com (enter hello@orions.agency), copy the
# Access Key here, and set the same value in Vercel → Project → Environment.
VITE_WEB3FORMS_KEY=""
